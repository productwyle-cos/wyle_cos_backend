# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── Security ──────────────────────────────────────────────────────────────────
# A strong random string used to authenticate requests from the mobile app
API_SECRET=change_this_to_a_strong_random_string

# ── AI (optional — falls back to rule-based if not set) ───────────────────────
ANTHROPIC_API_KEY=

# ── Session storage ───────────────────────────────────────────────────────────
# Directory where Baileys auth state is stored (relative to project root)
# NOTE: On Render free tier, this is ephemeral — sessions reset on restart.
# Upgrade to Render paid plan (persistent disk) or add MongoDB/Redis for prod.
AUTH_DIR=./auth_sessions

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (your Expo/app URL)
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006
